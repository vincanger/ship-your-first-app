---
interface Props {
  title?: string;
  description?: string;
  image?: string;
}
const {
  title = "Open Vibe — Vibe code your way to real web dev skills",
  description = "Learn to build web apps with an AI agent as your tutor. Free, open source, ten weeks, zero filler.",
  image = "assets/og-image.png",
} = Astro.props;
const base = import.meta.env.BASE_URL;
const ogImage = image.startsWith("http") ? image : new URL(`${base}${image}`, Astro.site).href;
const canonical = new URL(Astro.url.pathname, Astro.site).href;

const jsonLd = [
  {
    "@context": "https://schema.org",
    "@type": "Organization",
    "@id": "https://wasp.sh/#org",
    name: "Wasp",
    url: "https://wasp.sh",
    logo: "https://wasp.sh/img/lp/wasp-logo.webp",
    sameAs: [
      "https://github.com/wasp-lang",
      "https://discord.gg/rzdnErX",
    ],
  },
  {
    "@context": "https://schema.org",
    "@type": "WebSite",
    name: "Open Vibe",
    url: Astro.site!.toString(),
    publisher: { "@id": "https://wasp.sh/#org" },
  },
];
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href={`${base}assets/favicon.ico`} />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="theme-color" content="#001a42" />
    <meta name="color-scheme" content="light" />
    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Open Vibe" />
    <meta property="og:url" content={canonical} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={ogImage} />
    <meta property="og:image:width" content="1200" />
    <meta property="og:image:height" content="630" />
    <meta property="og:locale" content="en_US" />
    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />
    <link rel="sitemap" href={`${base}sitemap-index.xml`} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;500;600;700;800&family=Inter:wght@400;500;600;700&display=swap" />
    <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
  </head>
  <body>
    <slot />
  </body>
</html>

<style is:global>
  /* ---- Design tokens (Open SaaS) ---- */
  :root {
    --os-bg:              #ffffff;
    --os-bg-subtle:       #faf1e3;
    --os-bg-muted:        #f5f5f5;
    --os-fg:              #0a0a0a;
    --os-fg-muted:        #737373;
    --os-primary:         #001a42;
    --os-secondary:       #bc7508;
    --os-secondary-muted: #ecc89a;
    --os-accent:          #e5a659;
    --os-border:          #e5e5e5;
    --os-yellow:          #f5c518;
    --os-yellow-soft:     #ffdc5c;
    --os-font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
    --os-font-sans: "Inter", ui-sans-serif, system-ui, -apple-system, sans-serif;
    --os-shadow-card:    0px 1px 3px rgba(0,0,0,0.12);
    --os-shadow-lg:      0px 20px 40px -10px rgba(0,0,0,0.18);
  }
  *, *::before, *::after { box-sizing: border-box; }
  html, body { margin: 0; padding: 0; background: #fff; color: #0a0a0a; font-family: var(--os-font-sans); -webkit-font-smoothing: antialiased; overflow-x: clip; }
  em { font-style: italic; }
  .os-text-gradient {
    background: linear-gradient(to right, var(--os-secondary-muted), var(--os-secondary));
    -webkit-background-clip: text; background-clip: text;
    -webkit-text-fill-color: transparent; color: transparent;
  }
  @keyframes ovBlink { 0%, 50% { opacity: 1 } 50.01%, 100% { opacity: 0 } }
  @keyframes ovPulse { 0%, 100% { opacity: 0.3 } 50% { opacity: 1 } }
</style>
