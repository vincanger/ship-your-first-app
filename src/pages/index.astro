<section id="for-founders" style="padding:120px 32px;background:#fff">
  <div style="max-width:1120px;margin:0 auto">
    <div style="text-align:center;max-width:760px;margin:0 auto 56px">
      <div style="font-family:var(--os-font-mono);font-size:12px;font-weight:600;color:#bc7508;text-transform:uppercase;letter-spacing:1.2px;margin-bottom:14px">For aspiring founders</div>
      <h2 style="font-family:var(--os-font-mono);font-weight:700;font-size:40px;line-height:1.1;letter-spacing:-0.02em;margin:0;color:#0a0a0a">Learn only what you need while you build your SaaS.</h2>
      <p style="font-size:17px;line-height:1.55;color:#737373;margin-top:16px;margin-bottom:0">At the end of the course, you'll build your own SaaS with our free SaaS starter template, <a href="https://opensaas.sh" target="_blank" style="color:#0a0a0a;text-decoration:underline">Open SaaS</a> (a ~$300 value), and actually understand what you built.</p>
    </div>
    <div style="border-radius:20px;border:1px solid #f5e6c8;background:linear-gradient(180deg,#faf1e3 0%,#fff 75%);padding:40px 40px 36px;display:grid;grid-template-columns:1fr 1.4fr;gap:48px;align-items:center;position:relative;overflow:hidden">

      <!-- App deck carousel -->
      <div class="deck-wrap" style="position:relative;width:100%;height:340px;padding-top:1rem;display:flex;align-items:flex-start;justify-content:center;cursor:pointer;perspective:3400px">
        {deckApps.map(app => (
          <div class="deck-card" style="position:absolute;width:320px;height:220px;border-radius:12px;overflow:hidden;background:#fff;border:1px solid #e5e5e5;transition:transform .5s cubic-bezier(.2,.8,.2,1),opacity .35s ease">
            <a href={app.href} target="_blank">
              <div style="display:flex;align-items:center;gap:5px;padding:7px 10px;background:#f5f5f5;border-bottom:1px solid #e5e5e5;flex-shrink:0">
                <span style="width:7px;height:7px;border-radius:50%;background:#ff5f56"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#ffbd2e"></span>
                <span style="width:7px;height:7px;border-radius:50%;background:#27c93f"></span>
                <div style="margin-left:6px;padding:2px 8px;border-radius:4px;background:#fff;border:1px solid #e5e5e5;font-family:var(--os-font-mono);font-size:9px;color:#737373">{app.domain}</div>
              </div>
              <img src={app.img} alt={app.name} style="width:100%;height:calc(100% - 27px);object-fit:cover;object-position:top;display:block" />
            </a>
          </div>
        ))}
        <button class="deck-nav deck-prev" style="position:absolute;left:10px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid #e5e5e5;box-shadow:0 6px 14px rgba(0,0,0,0.12);display:flex;align-items:center;justify-content:center;font-family:var(--os-font-mono);font-size:16px;color:#0a0a0a;cursor:pointer;z-index:20">←</button>
        <button class="deck-nav deck-next" style="position:absolute;right:10px;top:50%;transform:translateY(-50%);width:36px;height:36px;border-radius:50%;background:#fff;border:1px solid #e5e5e5;box-shadow:0 6px 14px rgba(0,0,0,0.12);display:flex;align-items:center;justify-content:center;font-family:var(--os-font-mono);font-size:16px;color:#0a0a0a;cursor:pointer;z-index:20">→</button>
        <div style="position:absolute;bottom:-4px;left:50%;transform:translateX(-50%);display:flex;align-items:center;gap:10px">
          <div style="display:inline-flex;align-items:center;gap:8px;padding:6px 12px;border-radius:9999px;background:#fff;border:1px solid #e5e5e5;font-family:var(--os-font-mono);font-size:11px;font-weight:600;color:#0a0a0a;box-shadow:0 2px 8px rgba(0,0,0,0.04)">
            <span style="width:18px;height:18px;border-radius:50%;background:#f5c518;display:inline-flex;align-items:center;justify-content:center;font-weight:800;font-size:10px;color:#001a42">=&#125;</span>
            <span>Built with Open SaaS</span>
            <span style="color:#737373">· <span class="deck-counter">1/{deckApps.length}</span></span>
          </div>
        </div>
      </div>

      <!-- Features -->
      <div>
        <div style="font-family:var(--os-font-mono);font-size:11px;font-weight:700;color:#bc7508;letter-spacing:1.5px">FINAL MODULE</div>
        <div style="font-family:var(--os-font-mono);font-weight:700;font-size:22px;line-height:1.2;margin:8px 0 22px;color:#0a0a0a">Launch a real SaaS — on the same stack as other successful builders.</div>
        <div style="display:grid;grid-template-columns:repeat(3,1fr);gap:10px">
          {saasFeatures.map(f => (
            <div style={`padding:16px 14px;border-radius:12px;background:#fff;border:1px solid #e5e5e5;display:flex;align-items:center;gap:10px;box-shadow:var(--os-shadow-card)`}>
              <div style={`width:34px;height:34px;border-radius:9px;background:${f.color}22;color:${f.color};display:flex;align-items:center;justify-content:center;flex-shrink:0`}>
                <Fragment set:html={f.icon} />
              </div>
              <div style="font-family:var(--os-font-mono);font-weight:700;font-size:13.5px;color:#0a0a0a">{f.label}</div>
            </div>
          ))}
        </div>
        <div style="margin-top:18px;padding:12px 14px;background:#001a42;color:#fff;border-radius:10px;font-family:var(--os-font-mono);font-size:12.5px;line-height:1.45;display:flex;align-items:center;gap:10px">
          <span style="color:#f5c518">&gt;</span>
          <span>Let's deploy my SaaS app to the web!</span>
          <span style="margin-left:auto;color:rgba(255,255,255,0.5);font-size:11px">ready in ~5 min</span>
        </div>
      </div>
    </div>

    <!-- Bottom row -->
    <div style="margin-top:24px;display:grid;grid-template-columns:repeat(3,1fr);gap:16px">
      {[
        ["🚀","MIT-licensed","100% yours forever"],
        ["🛠","Built by Wasp","Same team, same quality bar"],
        ["💳","Accept payments","Make revenue right away!"],
      ].map(([emoji,t,sub]) => (
        <div style="padding:16px 18px;border-radius:12px;background:#fff;border:1px solid #e5e5e5;display:flex;align-items:center;gap:14px">
          <div style="width:38px;height:38px;border-radius:10px;background:#faf1e3;display:flex;align-items:center;justify-content:center;font-size:18px">{emoji}</div>
          <div>
            <div style="font-family:var(--os-font-mono);font-weight:700;font-size:14px;color:#0a0a0a">{t}</div>
            <div style="font-size:12.5px;color:#737373;margin-top:2px">{sub}</div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>

