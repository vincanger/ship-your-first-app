---
import Base from '../layouts/Base.astro';
const base = import.meta.env.BASE_URL;

const INSTALL_PROMPT = `I'm starting the "Ship Your First App" course. Fetch the following URL and follow the instructions: https://openvibe.sh/llms.txt`;

const navLinks = ["See it in action", "How it works", "Curriculum", "FAQ"];

const whyRows = [
  { feature: "Your tutor",          tutorials: "A recorded video",                    openvibe: "A live AI agent in your editor" },
  { feature: "What you build",      tutorials: "A toy clone you'll delete",           openvibe: "A real full-stack app on your machine" },
  { feature: "When you get stuck",  tutorials: "Rewind. Copy. Paste. Pray.",          openvibe: "Ask. The agent explains in your code." },
  { feature: "Pacing",              tutorials: "The instructor's speed",              openvibe: "Your speed — skip, slow down, go deep" },
  { feature: "Diagrams & concepts", tutorials: "Static slides",                       openvibe: "Interactive overlays on your real app" },
  { feature: "When it's outdated",  tutorials: "You're stuck with yesterday's tools", openvibe: "The agent updates with the ecosystem" },
  { feature: "Price",               tutorials: "$99 – $499 🤮",                       openvibe: "Free. Forever. 🤩" },
];

const deckApps = [
  { name: "Searchcraft",      domain: "searchcraft.io",       img: `${base}assets/examples/searchcraft.webp`,      href: "https://www.searchcraft.io" },
  { name: "Scribeist",        domain: "scribeist.com",         img: `${base}assets/examples/scribeist.webp`,        href: "https://scribeist.com" },
  { name: "Messync",          domain: "messync.com",           img: `${base}assets/examples/messync.webp`,          href: "https://messync.com" },
  { name: "Kivo",             domain: "kivo.dev",              img: `${base}assets/examples/kivo.webp`,             href: "https://kivo.dev" },
  { name: "Microinfluencers", domain: "microinfluencer.club",  img: `${base}assets/examples/microinfluencers.webp`, href: "https://microinfluencer.club" },
  { name: "Prompt Panda",     domain: "promptpanda.io",        img: `${base}assets/examples/promptpanda.webp`,      href: "https://promptpanda.io" },
  { name: "Review Radar",     domain: "reviewradar.ai",        img: `${base}assets/examples/reviewradar.webp`,      href: "https://reviewradar.ai" },
];

const saasFeatures = [
  { label: "Auth",     color: "#fbbf24", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="11" width="18" height="11" rx="2"/><path d="M7 11V7a5 5 0 0 1 10 0v4"/></svg>` },
  { label: "Payments", color: "#60a5fa", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="2" y="5" width="20" height="14" rx="2"/><line x1="2" y1="10" x2="22" y2="10"/></svg>` },
  { label: "Admin",    color: "#34d399", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M3 3v18h18"/><path d="M7 14l3-3 4 4 5-6"/></svg>` },
  { label: "Email",    color: "#f472b6", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><rect x="3" y="5" width="18" height="14" rx="2"/><path d="M3 7l9 7 9-7"/></svg>` },
  { label: "Blog",     color: "#a78bfa", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M14 3H6a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V9z"/><path d="M14 3v6h6"/></svg>` },
  { label: "AI-ready", color: "#fb923c", icon: `<svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 3v4M12 17v4M3 12h4M17 12h4M6 6l2.5 2.5M15.5 15.5L18 18M6 18l2.5-2.5M15.5 8.5L18 6"/></svg>` },
];

const phase1Modules = [
  { n: "Setup",    title: "Environment & tools",  status: "available" },
  { n: "Module 0", title: "Your First Web App",    status: "available" },
  { n: "Module 1", title: "Data & The Database",   status: "soon" },
  { n: "Module 2", title: "Making It Look Good",   status: "soon" },
  { n: "Module 3", title: "How It All Connects",   status: "soon" },
];

const faqs = [
  { q: "Is it really free?",                       a: "Yes. Open Vibe is 100% free and open source. The curriculum, the skills, the diagrams — all of it, under MIT. Fork it, remix it, run your own class with it." },
  { q: "Do I need to know how to code?",           a: "No. Open Vibe can be used by beginners or pros. You set the pace and focus your efforts as you see fit. If you can type, follow instructions, and stay curious, you can do this." },
  { q: "What agent does it work with?",            a: "It's been designed and tested in Claude Code but the course pack is plain Markdown and runs in any agent that can read files and execute tools." },
  { q: "Do I need an API key?",                    a: "You'll bring your own agent (Claude, Cursor, Codex, etc.) and its key or subscription. The course itself is free — we just teach on top of the tools you already use." },
  { q: "How long does it take?",                   a: "The curriculum is built for ten weeks at ~6 hrs/week. People blow through it in three; people take six months. Your agent is patient either way." },
  { q: "Is this a bootcamp with a certificate?",   a: "No. It's a course you do with an AI tutor. What you have at the end is three real apps in your GitHub and the knowledge to build more — which employers tend to find more convincing than paper." },
  { q: "Why 'Open Vibe'?",                         a: "Because vibe-coding with an agent is how we actually build in 2026 — and Open Vibe teaches you to do it well, instead of building fragile apps you don't understand." },
];
---

<Base>

<!-- ============================================================
     NavBar
============================================================ -->
<header style="position:sticky;top:0;z-index:50">
  <div style="background:rgba(255,255,255,.85);backdrop-filter:blur(12px);border-bottom:1px solid #e5e5e5">
    <nav style="max-width:1200px;margin:0 auto;display:flex;align-items:center;justify-content:space-between;padding:18px 32px">
      <div style="display:flex;align-items:center;gap:28px">
        <a href="#" style="display:flex;align-items:center;gap:10px;text-decoration:none;color:#0a0a0a">
          <img src={`${base}assets/logo.webp`} style="width:28px;height:28px" alt="" />
          <span style="font-family:var(--os-font-mono);font-weight:700;font-size:15px;letter-spacing:-0.01em">Open Vibe</span>
          <span style="margin-left:4px;padding:2px 8px;border-radius:9999px;background:#faf1e3;font-family:var(--os-font-mono);font-size:10px;font-weight:600;color:#bc7508;text-transform:uppercase;letter-spacing:0.8px">100% FREE</span>
        </a>
        <ul style="display:flex;gap:22px;list-style:none;margin:0;padding:0">
          {navLinks.map(l => (
            <li>
              <a href={`#${l.toLowerCase().replace(/\s+/g, "-")}`} style="font-size:14px;color:#0a0a0a;text-decoration:none;font-weight:500">{l}</a>
            </li>
          ))}
        </ul>
      </div>
      <div style="display:flex;align-items:center;gap:14px">
        <a href="https://github.com/wasp-lang/ship-your-first-app" target="_blank" style="font-size:14px;color:#0a0a0a;text-decoration:none;font-weight:500">GitHub ↗</a>
        <a href="#install" style="padding:9px 18px;border-radius:9999px;background:#001a42;color:#fafafa;font-size:13px;font-weight:600;text-decoration:none;font-family:var(--os-font-mono);display:inline-flex;align-items:center;gap:6px">Get Started <span style="opacity:0.7">→</span></a>
      </div>
    </nav>
  </div>
</header>

<!-- ============================================================
     Hero
============================================================ -->
<section style="padding:56px 32px 64px;background:linear-gradient(180deg,#faf1e3 0%,transparent 85%)">
  <div style="max-width:1200px;margin:0 auto;display:grid;grid-template-columns:1fr 1.1fr;gap:56px;align-items:center">

    <!-- Left: pitch -->
    <div>
      <!-- Announce bar -->
      <div style="display:inline-flex;align-items:center;gap:10px;padding:6px 14px 6px 8px;border-radius:9999px;background:#faf1e3;border:1px solid #f5e6c8;font-family:var(--os-font-mono);font-size:12px;font-weight:600">
        <span style="padding:2px 8px;border-radius:9999px;background:#f5c518;color:#001a42;font-size:10px;font-weight:700;letter-spacing:0.5px">NEW</span>
        <span style="color:#0a0a0a">v1.0 is live</span>
        <span style="color:#737373">→</span>
      </div>
      <h1 style="font-family:var(--os-font-mono);font-weight:800;font-size:clamp(40px,5.5vw,68px);line-height:1.02;letter-spacing:-0.035em;margin:24px 0 0;color:#0a0a0a;text-wrap:balance">
        Vibe code your way{" "}
        <span style="position:relative;display:inline-block">
          <span class="os-text-gradient">to real</span>
        </span>{" "}web dev skills.
      </h1>
      <p style="font-size:18px;line-height:1.6;color:#737373;max-width:540px;margin:26px 0 0">
        Stop watching videos. Start building. Open Vibe drops a full, interactive web dev curriculum into Claude Code
        (or your agent of choice) and lets you learn by shipping real apps.
      </p>
      <div style="margin-top:32px;display:flex;gap:12px;flex-wrap:wrap">
        <a href="#install" style="padding:14px 24px;border-radius:10px;background:#001a42;color:#fafafa;font-family:var(--os-font-mono);font-weight:700;font-size:14px;text-decoration:none;display:inline-flex;align-items:center;gap:8px">Get started — it's free <span>→</span></a>
        <a href="#how-it-works" style="padding:14px 24px;border-radius:10px;background:#fff;color:#0a0a0a;border:1px solid #e5e5e5;font-family:var(--os-font-mono);font-weight:600;font-size:14px;text-decoration:none">Watch a demo</a>
      </div>
      <div style="margin-top:28px;display:flex;gap:18px;flex-wrap:wrap;font-size:13px;color:#737373;font-family:var(--os-font-mono)">
        <span>✓ 100% free &amp; open source</span>
        <span>✓ No signup</span>
        <span>✓ MIT licensed</span>
      </div>
    </div>

    <!-- Right: fanned card mock -->
    <div style="position:relative">
      <div class="hero-cards">

        <!-- Card 1: Todo app (front) -->
        <div class="hero-card-front">
          <div style="background:#fff;border-radius:14px;border:1px solid #e5e5e5;box-shadow:0 30px 60px -20px rgba(0,0,0,0.25),0 10px 20px -8px rgba(0,0,0,0.1);overflow:hidden">
            <!-- Browser chrome -->
            <div style="display:flex;align-items:center;gap:8px;padding:10px 14px;background:#f5f5f5;border-bottom:1px solid #e5e5e5">
              <span style="width:10px;height:10px;border-radius:50%;background:#ff5f56"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#ffbd2e"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#27c93f"></span>
              <div style="flex:1;text-align:center;font-family:var(--os-font-mono);font-size:11px;color:#737373">My ToDo App</div>
            </div>
            <!-- App body -->
            <div style="padding:28px 32px 0;background:#fafafa">
              <!-- Create task card -->
              <div style="background:#fff;border-radius:12px;border:1px solid #e5e5e5;padding:20px 24px;box-shadow:var(--os-shadow-card)">
                <div style="font-family:var(--os-font-mono);font-weight:700;font-size:18px;margin-bottom:14px">Create a new task</div>
                <div style="display:flex;gap:10px;align-items:center">
                  <div style="flex:1;padding:10px 14px;border-radius:8px;border:1px solid #e5e5e5;font-size:13px;color:#737373;background:#fff">What do I need to do?</div>
                  <button style="position:relative;padding:10px 22px;border-radius:8px;background:#f5c518;border:none;font-size:14px;font-weight:700;font-family:var(--os-font-mono);color:#001a42;box-shadow:0 0 0 4px #f5c51833">
                    Create
                    <span style="position:absolute;right:-6px;top:-6px;width:12px;height:12px;border-radius:50%;background:#e5a659;animation:ovPulse 1.8s ease-in-out infinite"></span>
                  </button>
                </div>
              </div>
              <!-- Task list -->
              <div style="margin-top:10px;margin-bottom:14px;background:#fff;border-radius:10px;border:1px solid #e5e5e5;overflow:hidden">
                {[{t:"setup my app",d:"17/04/2026"},{t:"learn web dev",d:"17/04/2026"}].map((it, i, arr) => (
                  <div style={`display:flex;align-items:center;gap:12px;padding:10px 16px;${i < arr.length-1 ? "border-bottom:1px solid #e5e5e5" : ""}`}>
                    <span style="width:14px;height:14px;border-radius:3px;border:1.5px solid #e5e5e5;flex-shrink:0"></span>
                    <div style="flex:1">
                      <div style="font-size:13px;font-weight:500">{it.t}</div>
                      <div style="font-size:10.5px;color:#737373;margin-top:1px">{it.d}</div>
                    </div>
                    <span style="color:#737373;font-size:13px">→</span>
                  </div>
                ))}
              </div>
            </div>
            <!-- Behind-the-scenes drawer -->
            <div style="background:#15151a;color:#e6e6e6;padding:14px 22px 20px;border-top:3px solid #2a2a30">
              <div style="width:44px;height:4px;background:#3a3a42;border-radius:2px;margin:0 auto 12px"></div>
              <div style="display:flex;align-items:center;justify-content:space-between;margin-bottom:4px">
                <div>
                  <div style="font-family:var(--os-font-mono);font-size:10px;letter-spacing:1.5px;color:#8b8b92;font-weight:600">BEHIND THE SCENES</div>
                  <div style="font-family:var(--os-font-mono);font-size:16px;font-weight:700;margin-top:2px">How does adding a task work?</div>
                </div>
                <div style="display:flex;align-items:center;gap:12px;font-family:var(--os-font-mono);font-size:12px;color:#8b8b92">
                  <span><span style="color:#fff;font-weight:700">01</span>/06</span>
                  <span style="width:22px;height:22px;border-radius:6px;border:1px solid #3a3a42;display:inline-flex;align-items:center;justify-content:center;font-size:12px">✕</span>
                </div>
              </div>
              <!-- 3-node diagram -->
              <div style="margin-top:14px;border-radius:10px;padding:24px 18px;background:#0f0f13;background-image:radial-gradient(rgba(255,255,255,0.05) 1px,transparent 1px);background-size:18px 18px">
                <div style="display:grid;grid-template-columns:1fr auto 1fr auto 1fr;align-items:center;gap:14px">
                  <!-- Browser node -->
                  <div style="background:#1c1c22;border-radius:10px;border:1px solid #2a2a30;padding:16px 10px;text-align:center;color:#d0d0d6">
                    <div style="display:flex;align-items:center;justify-content:center;height:36px;margin-bottom:6px">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M9 17.25v1.007a3 3 0 0 1-.879 2.122L7.5 21h9l-.621-.621A3 3 0 0 1 15 18.257V17.25m6-12V15a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 15V5.25m18 0A2.25 2.25 0 0 0 18.75 3H5.25A2.25 2.25 0 0 0 3 5.25m18 0V12a2.25 2.25 0 0 1-2.25 2.25H5.25A2.25 2.25 0 0 1 3 12V5.25" /></svg>
                    </div>
                    <div style="font-family:var(--os-font-mono);font-size:11px;font-weight:700;color:#d0d0d6;letter-spacing:1.2px">BROWSER</div>
                    <div style="font-family:var(--os-font-mono);font-size:10px;color:#7a7a82;margin-top:2px">React</div>
                  </div>
                  <!-- Arrow 1 (active) -->
                  <div style="display:flex;align-items:center;justify-content:center;color:#f5c518;font-size:18px;animation:ovPulse 1.4s ease-in-out infinite">→</div>
                  <!-- Server node (highlight) -->
                  <div style="background:#1c1c22;border-radius:10px;border:1px solid #f5c518;box-shadow:0 0 0 4px #f5c51822;padding:16px 10px;text-align:center;color:#f5c518">
                    <div style="display:flex;align-items:center;justify-content:center;height:36px;margin-bottom:6px">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M10.343 3.94c.09-.542.56-.94 1.11-.94h1.093c.55 0 1.02.398 1.11.94l.149.894c.07.424.384.764.78.93.398.164.855.142 1.205-.108l.737-.527a1.125 1.125 0 0 1 1.45.12l.773.774c.39.389.44 1.002.12 1.45l-.527.737c-.25.35-.272.806-.107 1.204.165.397.505.71.93.78l.893.15c.543.09.94.559.94 1.109v1.094c0 .55-.397 1.02-.94 1.11l-.894.149c-.424.07-.764.383-.929.78-.165.398-.143.854.107 1.204l.527.738c.32.447.269 1.06-.12 1.45l-.774.773a1.125 1.125 0 0 1-1.449.12l-.738-.527c-.35-.25-.806-.272-1.203-.107-.398.165-.71.505-.781.929l-.149.894c-.09.542-.56.94-1.11.94h-1.094c-.55 0-1.019-.398-1.11-.94l-.148-.894c-.071-.424-.384-.764-.781-.93-.398-.164-.854-.142-1.204.108l-.738.527c-.447.32-1.06.269-1.45-.12l-.773-.774a1.125 1.125 0 0 1-.12-1.45l.527-.737c.25-.35.272-.806.108-1.204-.165-.397-.506-.71-.93-.78l-.894-.15c-.542-.09-.94-.56-.94-1.109v-1.094c0-.55.398-1.02.94-1.11l.894-.149c.424-.07.765-.383.93-.78.165-.398.143-.854-.108-1.204l-.526-.738a1.125 1.125 0 0 1 .12-1.45l.773-.773a1.125 1.125 0 0 1 1.45-.12l.737.527c.35.25.807.272 1.204.107.397-.165.71-.505.78-.929l.15-.894Z" /><path stroke-linecap="round" stroke-linejoin="round" d="M15 12a3 3 0 1 1-6 0 3 3 0 0 1 6 0Z" /></svg>
                    </div>
                    <div style="font-family:var(--os-font-mono);font-size:11px;font-weight:700;letter-spacing:1.2px">SERVER</div>
                    <div style="font-family:var(--os-font-mono);font-size:10px;color:#7a7a82;margin-top:2px">Node.js</div>
                  </div>
                  <!-- Arrow 2 -->
                  <div style="display:flex;align-items:center;justify-content:center;color:#5a5a62;font-size:18px">→</div>
                  <!-- DB node -->
                  <div style="background:#1c1c22;border-radius:10px;border:1px solid #2a2a30;padding:16px 10px;text-align:center;color:#d0d0d6">
                    <div style="display:flex;align-items:center;justify-content:center;height:36px;margin-bottom:6px">
                      <svg xmlns="http://www.w3.org/2000/svg" fill="none" viewBox="0 0 24 24" stroke-width="1.5" stroke="currentColor" width="28" height="28"><path stroke-linecap="round" stroke-linejoin="round" d="M20.25 6.375c0 2.278-3.694 4.125-8.25 4.125S3.75 8.653 3.75 6.375m16.5 0c0-2.278-3.694-4.125-8.25-4.125S3.75 4.097 3.75 6.375m16.5 0v11.25c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125V6.375m16.5 0v3.75m-16.5-3.75v3.75m16.5 0v3.75C20.25 16.153 16.556 18 12 18s-8.25-1.847-8.25-4.125v-3.75m16.5 0c0 2.278-3.694 4.125-8.25 4.125s-8.25-1.847-8.25-4.125" /></svg>
                    </div>
                    <div style="font-family:var(--os-font-mono);font-size:11px;font-weight:700;color:#d0d0d6;letter-spacing:1.2px">DATABASE</div>
                    <div style="font-family:var(--os-font-mono);font-size:10px;color:#7a7a82;margin-top:2px">PostgreSQL</div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>

        <!-- Card 2: Terminal (back) -->
        <div class="hero-card-back">
          <div style="background:#1b1b1f;border-radius:10px;box-shadow:0 30px 60px -20px rgba(0,0,0,0.4),0 10px 20px -8px rgba(0,0,0,0.25);overflow:hidden;border:1px solid #000">
            <!-- Terminal chrome -->
            <div style="display:flex;align-items:center;gap:8px;padding:9px 12px;background:#2a2a2e;border-bottom:1px solid #000">
              <span style="width:10px;height:10px;border-radius:50%;background:#ff5f56"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#ffbd2e"></span>
              <span style="width:10px;height:10px;border-radius:50%;background:#27c93f"></span>
              <div style="flex:1;text-align:center;font-family:var(--os-font-mono);font-size:10.5px;color:#c9c9cd;font-weight:500">📁 Open Vibe · Module 02</div>
            </div>
            <!-- Terminal body -->
            <div style="padding:14px 16px;color:#e6e6e6;font-family:var(--os-font-mono);font-size:13px;line-height:1.55">
              <div style="display:flex;gap:10px;margin-bottom:10px">
                <div style="width:30px;height:30px;border-radius:5px;background:#f5c518;display:flex;align-items:center;justify-content:center;color:#001a42;font-weight:800;font-size:14px;flex-shrink:0">=&#125;</div>
                <div style="font-size:11px">
                  <div style="font-weight:700">Open Vibe <span style="color:#9aa0a6;font-weight:400">v1.0.0</span></div>
                  <div style="color:#9aa0a6">~/my-todo-app</div>
                </div>
              </div>
              <div style="padding:5px 8px;background:#2a2a2e;border-radius:3px;margin-bottom:8px">
                <span style="color:#9aa0a6">&gt;&nbsp;</span>what happens behind the scenes when I click "add task"?
              </div>
              <div style="display:flex;gap:6px;margin-bottom:8px">
                <span style="color:#6cd07f">●</span>
                <span>Let me show you with a diagram on your app.</span>
              </div>
              <div style="display:flex;gap:6px;margin-bottom:4px">
                <span style="color:#6cd07f">●</span>
                <div>
                  <span style="font-weight:700">Diagram</span>
                  <span style="color:#9aa0a6"> (render "behind-the-scenes" · 1/6)</span>
                </div>
              </div>
