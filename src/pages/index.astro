<style>
  /* Hero card hover */
  .hero-cards {
    position: relative;
    width: 100%;
    height: 560px;
    perspective: 1400px;
  }
  .hero-card-front {
    position: absolute;
    left: 4%;
    top: 10px;
    width: 86%;
    z-index: 3;
    transform: rotate(-1deg);
    transition: transform .5s cubic-bezier(.2,.8,.2,1), filter .5s;
    transform-origin: center bottom;
  }
  .hero-card-back {
    position: absolute;
    right: -6%;
    top: 60px;
    width: 72%;
    z-index: 2;
    transform: rotate(6deg);
    filter: brightness(0.95);
    transition: transform .5s cubic-bezier(.2,.8,.2,1), filter .5s;
    transform-origin: center bottom;
  }
  .hero-cards:hover .hero-card-front {
    transform: translate(-18px, 36px) rotate(-5deg) scale(0.94);
    filter: brightness(0.96);
  }
  .hero-cards:hover .hero-card-back {
    transform: translate(-10px, -24px) rotate(-1deg) scale(1.04);
    z-index: 4;
    filter: none;
  }

  /* Video overlay */
  .demo-overlay.hidden { display: none; }

  /* Copy button copied state */
  [data-copy][data-copied] {
    background: #f5c518 !important;
    color: #001a42 !important;
    border: none !important;
  }

  /* Deck nav hover */
  .deck-wrap .deck-nav { opacity: 0; transition: opacity .2s; }
  .deck-wrap:hover .deck-nav { opacity: 1; }

  /* Curriculum row hover */
  .curriculum-row { transition: background .15s; }
  .curriculum-row:hover { background: rgba(250,241,227,.35); }
</style>

<script>
  // 1. Hero text streaming on first hover
  const heroCards = document.querySelector('.hero-cards');
  let hasStreamed = false;
  heroCards?.addEventListener('mouseenter', () => {
    if (hasStreamed) return;
    hasStreamed = true;
    const FULL = "It makes sense now! let's continue";
    const target = document.querySelector('.hero-stream-text');
    if (!target) return;
    let i = 0;
    const tick = () => {
      i++;
      target.textContent = FULL.slice(0, i);
      if (i < FULL.length) setTimeout(tick, 45 + Math.random() * 40);
    };
    setTimeout(tick, 350);
  });

  // 2. Video overlay
  const video = document.querySelector('.demo-video');
  const overlay = document.querySelector('.demo-overlay');
  video?.addEventListener('play', () => overlay?.classList.add('hidden'));
  video?.addEventListener('pause', () => overlay?.classList.remove('hidden'));
  video?.addEventListener('ended', () => overlay?.classList.remove('hidden'));
  overlay?.addEventListener('click', () => (video as HTMLVideoElement)?.play());

  // 3. Copy buttons
  document.querySelectorAll<HTMLButtonElement>('[data-copy]').forEach(btn => {
    btn.addEventListener('click', e => {
      e.stopPropagation();
      navigator.clipboard?.writeText(btn.dataset.copy ?? '');
      const orig = btn.textContent ?? '';
      btn.textContent = btn.dataset.copiedLabel ?? '✓ Copied';
      btn.dataset.copied = 'true';
      setTimeout(() => { btn.textContent = orig; delete btn.dataset.copied; }, 1500);
    });
  });

  // 4. AppsDeck carousel
  const deckCards = Array.from(document.querySelectorAll<HTMLElement>('.deck-card'));
  const deckTotal = deckCards.length;
  let deckIdx = 0;
  function renderDeck() {
    deckCards.forEach((card, i) => {
      const offset = (i - deckIdx + deckTotal) % deckTotal;
      const isFront = offset === 0;
      const z = deckTotal - offset;
      const dx = offset * 18, dy = offset * 10;
      const rot = offset === 0 ? -3 : offset * 3 - 2;
      card.style.transform = `translate(${dx}px,${dy}px) rotate(${rot}deg)`;
      card.style.zIndex = String(z);
      card.style.opacity = offset > 3 ? '0' : '1';
      card.style.pointerEvents = offset > 3 ? 'none' : 'auto';
      card.style.boxShadow = isFront
        ? '0 30px 60px -20px rgba(0,0,0,0.35),0 10px 20px -10px rgba(0,0,0,0.15)'
        : '0 18px 36px -14px rgba(0,0,0,0.25)';
    });
    const counter = document.querySelector('.deck-counter');
    if (counter) counter.textContent = `${deckIdx + 1}/${deckTotal}`;
  }
  document.querySelector('.deck-wrap')?.addEventListener('click', e => {
    if (!(e.target as Element).closest('.deck-nav')) {
      deckIdx = (deckIdx + 1) % deckTotal;
      renderDeck();
    }
  });
  document.querySelector('.deck-prev')?.addEventListener('click', e => {
    e.stopPropagation();
    deckIdx = (deckIdx - 1 + deckTotal) % deckTotal;
    renderDeck();
  });
  document.querySelector('.deck-next')?.addEventListener('click', e => {
    e.stopPropagation();
    deckIdx = (deckIdx + 1) % deckTotal;
    renderDeck();
  });
  if (deckTotal > 0) renderDeck();

  // 5. FAQ accordion
  let faqOpen = 0;
  document.querySelectorAll<HTMLElement>('.faq-item').forEach((item, i) => {
    const answer = item.querySelector<HTMLElement>('.faq-answer');
    const chevron = item.querySelector<HTMLElement>('.faq-chevron');
    item.querySelector('.faq-btn')?.addEventListener('click', () => {
      const wasOpen = faqOpen === i;
      document.querySelectorAll<HTMLElement>('.faq-answer').forEach(a => a.style.display = 'none');
      document.querySelectorAll<HTMLElement>('.faq-chevron').forEach(c => c.style.transform = 'none');
      document.querySelectorAll<HTMLElement>('.faq-item').forEach(it => it.style.background = 'rgba(255,255,255,.75)');
      faqOpen = -1;
      if (!wasOpen) {
        faqOpen = i;
        if (answer) answer.style.display = 'block';
        if (chevron) chevron.style.transform = 'rotate(180deg)';
        item.style.background = 'rgba(255,255,255,1)';
      }
    });
  });
</script>
